__pycache__/
*.py[cod]
*$py.class

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo

# Virtual environments
.env
.venv
env/
venv/
ENV/

# OS generated files
.DS_Store
Thumbs.db

